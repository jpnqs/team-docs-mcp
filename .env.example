# ── Team Docs MCP Server — Environment Configuration ──────────────────────
# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are used when unset.
# All variables use the TEAM_DOCS_MCP_ prefix to avoid collisions.

# Directory containing documents to index for semantic search.
# TEAM_DOCS_MCP_DOCS_DIR=./docs

# Directory where cached embedding indexes are stored.
# TEAM_DOCS_MCP_INDEXED_DIR=./docs/.cache

# Sentence-transformer model used for embeddings (ONNX via @xenova/transformers).
# TEAM_DOCS_MCP_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Comma-separated list of file extensions to include when scanning DOCS_DIR.
# TEAM_DOCS_MCP_ALLOWED_EXTENSIONS=.md,.txt,.json,.html,.htm,.csv

# Maximum file size in bytes. Files larger than this are skipped.
# TEAM_DOCS_MCP_MAX_FILE_SIZE_BYTES=20971520

# Number of words per text chunk when splitting documents.
# TEAM_DOCS_MCP_CHUNK_SIZE_WORDS=220

# Number of overlapping words between consecutive chunks.
# TEAM_DOCS_MCP_CHUNK_OVERLAP_WORDS=40
